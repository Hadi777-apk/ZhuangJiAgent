<UserControl x:Class="DevEnvInit.App.Views.DetectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="26,20,26,0">
            <StackPanel>
                <!-- Page header -->
                <StackPanel>
                    <TextBlock Text="环境检测" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="硬件信息、Windows 版本、磁盘空间与已安装软件状态"
                               FontSize="13" Foreground="{StaticResource BrushText}" />
                </StackPanel>

                <!-- Hero strip -->
                <Border CornerRadius="12" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                        Padding="20,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFBF3" Offset="0" />
                            <GradientStop Color="#FFFFFF" Offset="0.6" />
                            <GradientStop Color="#F0FDF4" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="AI Development Environment" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource BrushTitle}" />
                        <TextBlock Text="One-click deployment · Python · Git · Node.js · Docker · AI Tools"
                                   FontSize="12" Foreground="{StaticResource BrushText}" />
                        <StackPanel Orientation="Horizontal">
                            <Border CornerRadius="999" BorderThickness="1" Padding="8,3"
                                    Background="{StaticResource BrushSuccessBg}"
                                    BorderBrush="#6EE7B7">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="5" Height="5" Fill="{StaticResource BrushSuccess}" VerticalAlignment="Center" />
                                    <TextBlock Text="Windows Ready" FontSize="11" FontWeight="Medium"
                                               Foreground="{StaticResource BrushSuccess}" />
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="999" BorderThickness="1" Padding="8,3"
                                    Background="{StaticResource BrushSuccessBg}" BorderBrush="#6EE7B7">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="5" Height="5" Fill="{StaticResource BrushSuccess}" VerticalAlignment="Center" />
                                    <TextBlock Text="Administrator" FontSize="11" FontWeight="Medium"
                                               Foreground="{StaticResource BrushSuccess}" />
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="999" BorderThickness="1" Padding="8,3"
                                    Background="{StaticResource BrushSuccessBg}" BorderBrush="#6EE7B7">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="5" Height="5" Fill="{StaticResource BrushSuccess}" VerticalAlignment="Center" />
                                    <TextBlock Text="Internet Connected" FontSize="11" FontWeight="Medium"
                                               Foreground="{StaticResource BrushSuccess}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- System info cards -->
                <StackPanel>
                    <TextBlock Text="系统信息" Style="{StaticResource SectionLabelStyle}" />
                    <UniformGrid Rows="2" Columns="3" >
                        <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,6,6">
                            <StackPanel>
                                <TextBlock Text="🖥️" FontSize="18" />
                                <TextBlock Text="处理器" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushMutedText}" />
                                <TextBlock Text="Snapdragon X Elite" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushTitle}" />
                                <TextBlock Text="12 Core · NPU Ready" FontSize="11"
                                           Foreground="{StaticResource BrushText}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,6,6">
                            <StackPanel>
                                <TextBlock Text="🧠" FontSize="18" />
                                <TextBlock Text="内存" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushMutedText}" />
                                <TextBlock Text="16 GB" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushTitle}" />
                                <TextBlock Text="LPDDR5 · Available" FontSize="11"
                                           Foreground="{StaticResource BrushText}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="💾" FontSize="18" />
                                <TextBlock Text="C 盘可用" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushMutedText}" />
                                <TextBlock Text="143 GB" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushTitle}" />
                                <TextBlock Text="SSD · 充足" FontSize="11"
                                           Foreground="{StaticResource BrushText}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="🪟" FontSize="18" />
                                <TextBlock Text="操作系统" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushMutedText}" />
                                <TextBlock Text="Windows 11" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushTitle}" />
                                <TextBlock Text="专业教育版" FontSize="11"
                                           Foreground="{StaticResource BrushText}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="🔐" FontSize="18" />
                                <TextBlock Text="管理员" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushMutedText}" />
                                <TextBlock Text="已获取" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSuccess}" />
                                <TextBlock Text="Full Access" FontSize="11"
                                           Foreground="{StaticResource BrushText}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource InfoCardStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="📡" FontSize="18" />
                                <TextBlock Text="网络" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushMutedText}" />
                                <TextBlock Text="已连接" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSuccess}" />
                                <TextBlock Text="Online Mode" FontSize="11"
                                           Foreground="{StaticResource BrushText}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>

                <!-- Detection results -->
                <StackPanel>
                    <TextBlock Text="软件安装状态" Style="{StaticResource SectionLabelStyle}" />
                    <TextBlock Text="{Binding Summary}" FontSize="12"
                               Foreground="{StaticResource BrushMutedText}" Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding Results}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,0,5"
                                        Padding="12,10">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center">
                                            <Border CornerRadius="999" Padding="8,3" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFFBEB" />
                                                        <Setter Property="BorderBrush" Value="#FCD34D" />
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource BrushWarning}" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="{Binding PackageName}" FontSize="13"
                                                       FontWeight="Medium" Foreground="{StaticResource BrushTitle}" />
                                            <TextBlock Text="{Binding Message}" FontSize="11"
                                                       Foreground="{StaticResource BrushMutedText}" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                Padding="26,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="开始检测" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding RunDetectionCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding Summary}" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource BrushMutedText}" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
