<Window x:Class="ZhuangJiAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZhuangJiAgent"
        xmlns:converters="clr-namespace:ZhuangJiAgent.Converters"
        mc:Ignorable="d"
        Title="装机 Agent - 软件批量部署工具"
        Height="700"
        Width="1000"
        MinHeight="500"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="装机 Agent" FontSize="20" FontWeight="Bold" Foreground="#333333"/>
                    <TextBlock Text="v1.0.0" FontSize="12" Foreground="#999999" Margin="10,0,0,0" VerticalAlignment="Center"/>

                    <!-- 搜索框 -->
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="200"
                             Height="32"
                             Margin="30,0,0,0"
                             VerticalContentAlignment="Center"
                             Padding="8"
                             BorderBrush="#E0E0E0"
                             BorderThickness="1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="搜索软件..."
                                                                   Foreground="#AAAAAA"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- 分类过滤 -->
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              Width="120"
                              Height="32"
                              Margin="10,0,0,0"
                              VerticalContentAlignment="Center"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⚙ 设置"
                            Command="{Binding OpenSettingsCommand}"
                            Width="80"
                            Height="32"
                            Margin="0,0,10,0"
                            Background="#607D8B"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Content="全选"
                            Command="{Binding SelectAllCommand}"
                            Width="80"
                            Height="32"
                            Margin="0,0,10,0"
                            Background="#9E9E9E"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Content="取消全选"
                            Command="{Binding UnselectAllCommand}"
                            Width="80"
                            Height="32"
                            Margin="0,0,10,0"
                            Background="#9E9E9E"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Content="检查更新"
                            Command="{Binding CheckUpdateCommand}"
                            Width="100"
                            Height="32"
                            Margin="0,0,10,0"
                            Background="#2196F3"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Content="应用更新"
                            Command="{Binding ApplyUpdatesCommand}"
                            Width="100"
                            Height="32"
                            Margin="0,0,10,0"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Content="安装选中"
                            Command="{Binding InstallSelectedCommand}"
                            Width="100"
                            Height="32"
                            Background="#FF9800"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 软件包列表 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <ItemsControl ItemsSource="{Binding PackagesView}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="280"
                                Height="180"
                                Background="White"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,15,15"
                                Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 标题栏 -->
                                <Grid Grid.Row="0">
                                    <CheckBox IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#333333"
                                               Margin="25,0,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>

                                <!-- 内容 -->
                                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11"
                                               Foreground="#666666"
                                               TextWrapping="Wrap"
                                               MaxHeight="40"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- 进度条 -->
                                <ProgressBar Grid.Row="2"
                                             Value="{Binding ProgressPercentage}"
                                             Height="4"
                                             Margin="0,4,0,4"
                                             Minimum="0"
                                             Maximum="100"
                                             Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                             Foreground="#2196F3"/>

                                <!-- 状态信息 -->
                                <TextBlock Grid.Row="3"
                                           Text="{Binding StatusMessage}"
                                           FontSize="10"
                                           Foreground="#FF9800"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,4"
                                           Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                                <!-- 底部信息 -->
                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               FontSize="11"
                                               Foreground="#999999">
                                        <Run Text="{Binding Category}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding Version}"/>
                                    </TextBlock>

                                    <Border Grid.Column="1"
                                            Background="#FFF3CD"
                                            CornerRadius="3"
                                            Padding="5,2"
                                            Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="有更新"
                                                   FontSize="10"
                                                   Foreground="#856404"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="#666666"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Foreground="#999999">
                        <Run Text="网络状态: "/>
                        <Run Text="{Binding NetworkState}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 加载遮罩 -->
        <Border Grid.RowSpan="3"
                Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="正在加载..."
                           FontSize="16"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
