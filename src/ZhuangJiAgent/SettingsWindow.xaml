<Window x:Class="ZhuangJiAgent.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZhuangJiAgent"
        mc:Ignorable="d"
        Title="设置"
        Height="500"
        Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- 设置内容 -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,20">
                <!-- 网络设置 -->
                <TextBlock Text="网络设置" FontSize="16" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>

                <CheckBox IsChecked="{Binding ForceOfflineMode}"
                          Content="强制离线模式（不连接网络）"
                          Margin="0,0,0,15"/>

                <CheckBox IsChecked="{Binding AutoCheckUpdates}"
                          Content="启动时自动检查更新"
                          Margin="0,0,0,20"/>

                <TextBlock Text="远程清单 URL（可选）:" Margin="0,0,0,5" Foreground="#666666"/>
                <TextBox Text="{Binding RemoteManifestUrl, UpdateSourceTrigger=PropertyChanged}"
                         Height="32"
                         Padding="8"
                         Margin="0,0,0,30"/>

                <!-- 下载设置 -->
                <TextBlock Text="下载设置" FontSize="16" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>

                <TextBlock Text="下载目录:" Margin="0,0,0,5" Foreground="#666666"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding DownloadDirectory, UpdateSourceTrigger=PropertyChanged}"
                             Height="32"
                             Padding="8"
                             VerticalContentAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="浏览..."
                            Command="{Binding BrowseFolderCommand}"
                            Width="80"
                            Height="32"
                            Margin="10,0,0,0"
                            Background="#2196F3"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </Grid>

                <TextBlock Text="并发下载数（1-5）:" Margin="0,0,0,5" Foreground="#666666"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                    <Slider Value="{Binding MaxConcurrentDownloads}"
                            Minimum="1"
                            Maximum="5"
                            Width="200"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MaxConcurrentDownloads}"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="15,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 状态消息 -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#4CAF50"
                           Margin="0,10,0,0"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,0">
                <Button Content="重置"
                        Command="{Binding ResetCommand}"
                        Width="100"
                        Height="36"
                        Margin="0,0,10,0"
                        Background="#9E9E9E"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
                <Button Content="保存"
                        Command="{Binding SaveCommand}"
                        Width="100"
                        Height="36"
                        Background="#4CAF50"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
