<UserControl x:Class="DevEnvInit.App.Views.InstallProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="26,20,26,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Page header spans full width -->
            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,14">
                <TextBlock Text="执行安装" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="Dry-run 模式：模拟安装流程，不执行真实安装器；阶段完成后接入真实调用"
                           FontSize="13" Foreground="{StaticResource BrushText}" />
            </StackPanel>

            <!-- Left: Progress card -->
            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                <StackPanel>
                    <!-- Big percent + ETA -->
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" VerticalAlignment="Bottom"
                                   FontSize="12" Foreground="{StaticResource BrushMutedText}"
                                   Text="预计剩余 —" />
                        <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:F0}%}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource BrushTitle}" />
                    </DockPanel>

                    <!-- Progress bar -->
                    <ProgressBar Value="{Binding ProgressPercent}" Height="8" Maximum="100"
                                 BorderThickness="0"
                                 Background="{StaticResource BrushBorder}"
                                 Foreground="{StaticResource BrushPrimary}" />

                    <!-- Item list -->
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BrushBackground}"
                                        CornerRadius="6" Padding="10,8" Margin="0,0,0,5">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding LogMessage}"
                                                   FontSize="11" Foreground="{StaticResource BrushMutedText}"
                                                   VerticalAlignment="Center" />
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="10" Height="10" Fill="{StaticResource BrushBorder}"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding PackageName}" FontSize="13"
                                                       FontWeight="Medium" Foreground="{StaticResource BrushTitle}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Right: Terminal -->
            <Border Grid.Row="1" Grid.Column="2" CornerRadius="12" ClipToBounds="True"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!-- Terminal title bar -->
                    <Border Grid.Row="0" Background="#1F2937" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#FF605C" />
                            <Ellipse Width="10" Height="10" Fill="#FFBD44" />
                            <Ellipse Width="10" Height="10" Fill="#00CA4E" />
                            <TextBlock Text="OUTPUT" FontSize="11" Foreground="#80FFFFFF"
                                       FontFamily="Cascadia Code, Consolas" Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <!-- Log lines -->
                    <ScrollViewer Grid.Row="1" Background="#111827"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="14,10">
                        <ItemsControl ItemsSource="{Binding LogLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Cascadia Code, Consolas"
                                               FontSize="11.5" Foreground="#D1D5DB"
                                               TextWrapping="Wrap" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                Padding="26,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="启动安装"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding StartInstallCommand}" />
                <TextBlock Text="{Binding Summary}" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource BrushMutedText}" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
