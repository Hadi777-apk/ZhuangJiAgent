<UserControl x:Class="DevEnvInit.App.Views.PathConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="路径配置" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="确认或修改安装根目录 — 下载和临时目录自动跟随。本页不放命令预览区域。" Margin="0,12,0,0" Foreground="{StaticResource BrushMutedText}" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,18,0,12">
                <TextBlock Text="安装根目录" Foreground="{StaticResource BrushMutedText}" FontSize="12" />
                <TextBox Text="{Binding InstallRoot, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" Background="{StaticResource BrushSurfaceAlt}" Foreground="{StaticResource BrushText}" BorderBrush="{StaticResource BrushBorder}" Padding="10,8" />

                <TextBlock Text="下载缓存目录（自动跟随）" Margin="0,10,0,0" Foreground="{StaticResource BrushMutedText}" FontSize="12" />
                <TextBox Text="{Binding DownloadDirectory}" Margin="0,4,0,0" Background="{StaticResource BrushSurfaceAlt}" Foreground="{StaticResource BrushMutedText}" BorderBrush="{StaticResource BrushBorder}" Padding="10,8" IsReadOnly="True" />

                <TextBlock Text="临时解压目录（自动跟随）" Margin="0,10,0,0" Foreground="{StaticResource BrushMutedText}" FontSize="12" />
                <TextBox Text="{Binding TempDirectory}" Margin="0,4,0,0" Background="{StaticResource BrushSurfaceAlt}" Foreground="{StaticResource BrushMutedText}" BorderBrush="{StaticResource BrushBorder}" Padding="10,8" IsReadOnly="True" />
            </StackPanel>

            <DockPanel Grid.Row="2" Margin="0,0,0,12">
                <Button DockPanel.Dock="Right" Content="检查空间" Padding="18,8" Command="{Binding CheckSpaceCommand}" />
                <TextBlock Text="{Binding Summary}" VerticalAlignment="Center" Foreground="{StaticResource BrushMutedText}" TextWrapping="Wrap" />
            </DockPanel>

            <TextBlock Grid.Row="3" Text="可用磁盘" Foreground="{StaticResource BrushAccent}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6" />

            <DataGrid Grid.Row="4" ItemsSource="{Binding Drives}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="{StaticResource BrushSurfaceAlt}" Foreground="{StaticResource BrushText}" BorderBrush="{StaticResource BrushBorder}" GridLinesVisibility="None">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="驱动器" Binding="{Binding Name}" Width="80" />
                    <DataGridTextColumn Header="标签" Binding="{Binding VolumeLabel}" Width="160" />
                    <DataGridTextColumn Header="总大小" Binding="{Binding TotalSize}" Width="120" />
                    <DataGridTextColumn Header="可用空间" Binding="{Binding AvailableFree}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
